# Copy to .env and fill in. All paths are relative to meeting_bot/ unless absolute.

# Recall.ai (required for bot + transcript)
RECALL_API_KEY=your_recall_api_key

# Gmail: put gmail-credentials.json in meeting_bot/credentials/
# Then run: python -m meeting_bot.run --auth-only
# (Optional; run.py uses meeting_bot/credentials/ by default)
# GMAIL_CREDENTIALS_PATH=credentials/gmail-credentials.json
# GMAIL_TOKEN_PATH=credentials/gmail-token.pickle

# Where to send summary email (default: same as Gmail account)
SUMMARY_EMAIL_TO=you@example.com

# Join window: create bot when meeting starts in N minutes (default 15)
JOIN_WINDOW_MINUTES=15
# Grace: still join if meeting started N minutes ago (default 5)
JOIN_GRACE_MINUTES=5
# Set to false to pause joining (e.g. vacation)
JOIN_ENABLED=true

# Bot display name in the meeting
BOT_NAME=Notetaker
