APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./gerald.db

X_BEARER_TOKEN=
# OAuth 2.0 user access token (Bearer) for posting tweets/replies; see docs/reference/x-api-manage-posts.md
X_USER_ACCESS_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

ANTHROPIC_API_KEY=
# 2026: claude-haiku-4-5 (budget), claude-sonnet-4-6 (balanced), claude-opus-4-6 (performance)
ANTHROPIC_CHEAP_MODEL=claude-haiku-4-5
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-6
ANTHROPIC_PERFORMANCE_MODEL=claude-opus-4-6

DEFAULT_LOOKBACK_DAYS=7
DEFAULT_MAX_PROSPECTS=25
DEFAULT_MAX_POSTS_PER_USER=20

# After a successful DM, wait this many seconds then post a public reply to their latest tweet
FOLLOW_UP_REPLY_ENABLED=true
FOLLOW_UP_REPLY_DELAY_SECONDS=300

