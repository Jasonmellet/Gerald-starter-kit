<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.xsystem-research</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>{{REPO_ROOT}}/tools/x_system_job.sh</string>
    <string>research</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>7</integer>
    <key>Minute</key>
    <integer>50</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>{{REPO_ROOT}}/tools/x_system_logs/research.log</string>
  <key>StandardErrorPath</key>
  <string>{{REPO_ROOT}}/tools/x_system_logs/research.err</string>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>

